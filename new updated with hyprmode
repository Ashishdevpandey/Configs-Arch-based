EOF
echo "   ✅ Fastfetch config restored"

# --------------------------------------------
# 8. INSTALL REQUIRED PACKAGES
# --------------------------------------------
echo "[8/9] Installing required packages..."
sudo pacman -S --noconfirm alacritty grimblast fastfetch waybar hyprland hyprmode 2>/dev/null
echo "   ✅ Packages installed"

# --------------------------------------------
# 9. ENABLE HYPREXPO PLUGIN
# --------------------------------------------
echo "[9/9] Enabling Hyprexpo plugin..."
if command -v hyprpm &> /dev/null; then
    hyprpm add https://github.com/hyprwm/hyprland-plugins 2>/dev/null
    hyprpm enable hyprexpo 2>/dev/null
    echo "   ✅ Hyprexpo plugin enabled"
else
    echo "   ⚠️  hyprpm not found - install manually"
fi

# --------------------------------------------
# RELOAD HYPRLAND
# --------------------------------------------
echo ""
echo "╔══════════════════════════════════════════╗"
echo "║   ✅ RESTORE COMPLETE!                   ║"
echo "╚══════════════════════════════════════════╝"
echo ""
echo "Now run: hyprctl reload"
echo "Or press: SUPER + SHIFT + R"
echo ""
hyprctl reload 2>/dev/null && echo "✅ Hyprland reloaded!" || echo "⚠️  Run 'hyprctl reload' manually"
